{
    "name": "leamix/cbr-php",
    "description": "Framework-agnostic PHP adapter for the Central Bank of Russia (CBR) XML API",
    "keywords": ["cbr", "central-bank-russia", "currency-rates", "xml", "api", "php"],
    "homepage": "https://github.com/leamix/cbr-php",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Alexander Levin",
            "email": "x8p@leamix.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "suggest": {
        "guzzlehttp/guzzle": "Wrap in an HttpClientInterface adapter for production-grade HTTP (retries, connection pooling, logging)"
    },
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Leamix\\CbrPhp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Leamix\\CbrPhp\\Tests\\": "tests/"
        }
    }
}
